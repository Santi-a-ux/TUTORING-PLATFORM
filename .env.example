# ─── BASE DE DATOS ─────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ttp
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ttp

# ─── JWT ────────────────────────────────────────────────────────────────────────
# IMPORTANTE: Cambia este valor en producción con: openssl rand -hex 32
JWT_SECRET=CAMBIA_ESTO_EN_PRODUCCION_usa_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── REDIS ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ─── SUPABASE STORAGE ───────────────────────────────────────────────────────────
# Obtén estos valores en: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
SUPABASE_KEY=tu_supabase_anon_key_aqui
SUPABASE_BUCKET=ttp-media

# ─── MAPBOX ─────────────────────────────────────────────────────────────────────
# Obtén tu token en: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiTU9ESUZJQ0FfRVNURV9UT0tFTiIsImEiOiJjaVRPTUVOIElFIn0.PLACEHOLDER

# ─── RESEND (EMAIL) ──────────────────────────────────────────────────────────────
# Obtén tu API key en: https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=noreply@tuplatforma.com
RESEND_FROM_NAME=Plataforma Tutores

# ─── URLs INTERNAS DE SERVICIOS (Docker network) ─────────────────────────────────
AUTH_SERVICE_URL=http://auth-service:8001
USER_SERVICE_URL=http://user-service:8002
TUTOR_SERVICE_URL=http://tutor-service:8003
GEO_SERVICE_URL=http://geo-service:8004
CHAT_SERVICE_URL=http://chat-service:8005
MEDIA_SERVICE_URL=http://media-service:8006

# ─── URLs PÚBLICAS (para desarrollo local sin Docker) ────────────────────────────
# Descomenta estas si corres los servicios directamente con uvicorn
# AUTH_SERVICE_URL=http://localhost:8001
# USER_SERVICE_URL=http://localhost:8002
# TUTOR_SERVICE_URL=http://localhost:8003
# GEO_SERVICE_URL=http://localhost:8004
# CHAT_SERVICE_URL=http://localhost:8005
# MEDIA_SERVICE_URL=http://localhost:8006

# ─── FRONTEND ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=TutorMatch
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── ENTORNO ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info
